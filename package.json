{
  "name": "strength-of-thousands",
  "version": "0.0.1",
  "description": "GM tools and teaching workspace for Pathfinder 2e Strength of Thousands.",
  "productName": "Strength of Thousands",
  "author": "David Perry <enmaku@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,css,html,md,json}\" --ignore-path .gitignore",
    "dev": "quasar dev",
    "build": "quasar build",
    "postbuild": "node ./scripts/copy-teaching-assets.mjs",
    "build:pages": "GH_PAGES_BASE=/strength-of-thousands/ npm run build",
    "postinstall": "quasar prepare",
    "test": "vitest run"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "diff": "^9.0.0",
    "pinia": "^3.0.1",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@quasar/app-vite": "2.5.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "postcss": "^8.4.14",
    "prettier": "^3.3.3",
    "vite-plugin-checker": "^0.11.0",
    "vitest": "^3.2.6",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
